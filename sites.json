{
    "countries": {
        "USA": {
            "selectors": [
                ".tsg-rwd-main-copy-body-frame",
                ".tsg-rwd-main-copy-frame"
            ],
            "use_dynamic": true
        },
        "UK": {
            "selectors": [
                "main",
                ".govuk-main-wrapper",
                "#main-content",
                "article"
            ],
            "use_dynamic": false
        },
        "DEFAULT": {
            "selectors": [
                "main",
                "article",
                "div[id='content']",
                "body"
            ],
            "use_dynamic": false
        }
    },
    "exclusions": {
        "tags": [
            "header",
            "footer",
            "aside",
            "nav",
            "style",
            "script",
            "noscript",
            "meta",
            "link",
            "svg"
        ],
        "phrases": [
            "apply now",
            "share this page",
            "cookie policy",
            "accept cookies",
            "read more",
            "cookies"
        ]
    }
}
